#:culture{:id "bol.dish.saltena", :name "Salteña", :country "BOL", :kind :dish, :summary "Bolivian type of baked empanada filled with beef, pork or chicken in a sweet, slightly spicy, juicy gelatin-based stew; found in any town or city throughout the country, traditionally as a mid-morning snack.", :url "https://en.wikipedia.org/wiki/Salte%C3%B1a", :url-provenance :wikipedia-en, :retrieved-at "2026-07-17"}
#:culture{:id "bol.dish.pique-macho", :name "Pique macho", :country "BOL", :kind :dish, :summary "Bolivian dish of beef, sausage, red onion, green pepper, tomato and french fries that originated in the Cochabamba Department in the mid-1970s; one of the country's most popular dishes.", :url "https://en.wikipedia.org/wiki/Pique_macho", :url-provenance :wikipedia-en, :retrieved-at "2026-07-17"}
#:culture{:url "https://en.wikipedia.org/wiki/Silpancho", :id "bol.dish.silpancho", :kind :dish, :name-local "Sillp'anchu", :country "BOL", :retrieved-at "2026-07-17", :summary "Popular Bolivian food from the city of Cochabamba: a base layer of rice, boiled and sliced potatoes, a thin layer of pounded meat and chopped tomato.", :name "Silpancho", :url-provenance :wikipedia-en}
#:culture{:id "bol.beverage.singani", :name "Singani", :country "BOL", :kind :beverage, :summary "Bolivian brandy distilled from Muscat of Alexandria grapes grown at 1,600 m or higher; the country's national distilled spirit, considered part of its cultural patrimony and protected as a geographical indication.", :url "https://en.wikipedia.org/wiki/Singani", :url-provenance :wikipedia-en, :retrieved-at "2026-07-17"}
#:culture{:id "bol.product.chuno", :name "Chuño", :country "BOL", :kind :product, :summary "Preserved potato product traditionally made by Quechua and Aymara communities of Bolivia and Peru through natural freeze-drying in the Andean Altiplano; predates the Inca Empire.", :url "https://en.wikipedia.org/wiki/Chu%C3%B1o", :url-provenance :wikipedia-en, :retrieved-at "2026-07-17"}
#:culture{:url "https://en.wikipedia.org/wiki/Carnaval_de_Oruro", :id "bol.festival.carnaval-de-oruro", :kind :festival, :name-local "Carnaval de Oruro", :country "BOL", :retrieved-at "2026-07-17", :summary "Religious and cultural festival in Oruro, Bolivia blending indigenous traditions with devotion to the Virgin of Socavón; proclaimed a UNESCO Masterpiece of the Oral and Intangible Heritage of Humanity in 2001.", :name "Carnival of Oruro", :url-provenance :wikipedia-en}
#:culture{:id "bol.heritage.tiwanaku", :name "Tiwanaku", :country "BOL", :kind :heritage, :summary "Pre-Columbian archaeological site in western Bolivia near Lake Titicaca, spiritual and political centre of the Tiwanaku culture; designated a UNESCO World Heritage Site in 2000.", :url "https://en.wikipedia.org/wiki/Tiwanaku", :url-provenance :wikipedia-en, :retrieved-at "2026-07-17"}
#:culture{:url "https://en.wikipedia.org/wiki/Potos%C3%AD", :id "bol.heritage.potosi", :kind :heritage, :name-local "Potosí", :country "BOL", :retrieved-at "2026-07-17", :summary "High-altitude Bolivian mining city whose Cerro Rico produced an estimated 60% of all silver mined in the world in the second half of the 16th century; a UNESCO World Heritage Site since 1987.", :name "City of Potosí", :url-provenance :wikipedia-en}
